# Google AI Studio — used by Google ADK (adk run, Runner, adk web)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-api-key-here

# DashScope (Alibaba Qwen) — used when switching to Qwen models via LiteLLM
# Get your key at: https://dashscope.console.aliyun.com/apiKey
# NOTE: keys are region-bound. International (Singapore) keys MUST use the
# -intl endpoint (the default below); China-mainland keys use the non-intl one.
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen3.7-plus
# Override only if using a China-mainland key:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
