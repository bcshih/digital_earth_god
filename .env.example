# Google AI Studio — used by Google ADK (adk run, Runner, adk web)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-api-key-here

# DashScope (Alibaba Qwen) — used when switching to Qwen models via LiteLLM
# Get your key at: https://dashscope.console.aliyun.com/apiKey
# Confirm model ID in DashScope console (e.g. qwen-plus, qwen-plus-latest)
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_MODEL=qwen-plus
